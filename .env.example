# Copie para .env e preencha. NUNCA commite o .env real.

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (use a SERVICE_ROLE key, NÃO a anon — essa é só do backend)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...

# CORS — domínios autorizados do frontend em produção, separados por vírgula
# Use "*" só em desenvolvimento.
ALLOWED_ORIGINS=https://arcane.app,https://www.arcane.app

# Kirvano — token que você vai configurar no painel da Kirvano ao criar o webhook.
# Gere um valor longo e aleatório (ex: 48 chars). Precisa ser o MESMO valor no painel da Kirvano.
KIRVANO_WEBHOOK_TOKEN=troque-isso-por-um-token-longo-aleatorio
